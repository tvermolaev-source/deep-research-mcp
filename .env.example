# SearXNG (запущен как отдельный контейнер)
SEARXNG_URL=http://searxng:8080
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=ru
SEARXNG_ENGINES=google,bing,duckduckgo
SEARXNG_SAFESEARCH=0

# OpenAI-совместимый endpoint (для LLM-планирования/суммаризации)
# например, Ollama локально или Open WebUI proxy
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# Embeddings (опционально, для дедупликации)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# MCP сервер
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Лимиты
MAX_ITERATIONS_QUALITY=25
MAX_ITERATIONS_BALANCED=6
MAX_ITERATIONS_SPEED=2
MAX_PARALLEL_CRAWLS=5
MAX_RESULTS_PER_QUERY=10
CRAWL_TIMEOUT_SEC=60

# ── Реранкинг выдачи SearXNG ───────────────────────────────────────
# Researcher автоматически распознаёт намерение пользователя по тексту
# запроса («ищи в социальных сетях», «научный факт-чек», «новости»,
# «ищи всё») и применяет соответствующую политику реранкинга.
# Адаптивные списки ниже УЖЕ заполнены авторитетными источниками
# мирового уровня — ничего не блокируем, только поднимаем в топ.
# Чтобы полностью переопределить набор — раскомментируйте и замените.

# Отбрасывать результаты с score ниже порога. 0.0 = не фильтровать.
MIN_RESULT_SCORE=0.0
RESULTS_TOP_K_PER_QUERY=10
DOMAIN_BOOST_THRESHOLD=2

# ── Домены (по дефолту списки заполнены в config.py) ──────────────
# Если нужно поднять в топ нейтрального режима конкретные сайты —
# задайте PRIORITY_DOMAINS. Если нужно что-то отсечь — задайте BLOCKED_DOMAINS.
#PRIORITY_DOMAINS=
#BLOCKED_DOMAINS=

# ── Адаптивные режимы (подсказка «ищи в …») ───────────────────────
# Чтобы полностью заменить дефолтный набор — раскомментируйте переменную.
#SOCIAL_DOMAINS=twitter.com,x.com,reddit.com,facebook.com,instagram.com,linkedin.com,tiktok.com
#ACADEMIC_DOMAINS=.edu,arxiv.org,scholar.google.com,pubmed.ncbi.nlm.nih.gov,nature.com,science.org,jstor.org
#NEWS_DOMAINS=reuters.com,apnews.com,bbc.com,nytimes.com,washingtonpost.com,ft.com,bloomberg.com

# Вкл/выкл детектор намерений. true / 1 / yes = работает.
INTENT_DETECTION=true

# Свои ключевые слова для каждого режима (через запятую).
# Если оставить пустым — используются встроенные RU+EN ключевики.
#INTENT_KEYWORDS_SOCIAL=соцсет,в соц,twitter
#INTENT_KEYWORDS_ACADEMIC=научн,факт-чек,arxiv
#INTENT_KEYWORDS_NEWS=новост,сми,news
#INTENT_KEYWORDS_ALL=ищи всё,включи все,comprehensive search
