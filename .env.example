# SearXNG (запущен как отдельный контейнер)
SEARXNG_URL=http://searxng:8080
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=ru
SEARXNG_ENGINES=google,bing,duckduckgo
SEARXNG_SAFESEARCH=0

# OpenAI-совместимый endpoint (для LLM-планирования/суммаризации)
# например, Ollama локально или Open WebUI proxy
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# Embeddings (опционально, для дедупликации)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# MCP сервер
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Лимиты
MAX_ITERATIONS_QUALITY=25
MAX_ITERATIONS_BALANCED=6
MAX_ITERATIONS_SPEED=2
MAX_PARALLEL_CRAWLS=5
MAX_RESULTS_PER_QUERY=10
CRAWL_TIMEOUT_SEC=60

# ── Реранкинг выдачи SearXNG ───────────────────────────────────────
# Мы НЕ блокируем и НЕ приоритизируем источники по умолчанию.
# По дефолту Researcher берёт всё, что вернул SearXNG, реранкирует
# по score + частотности домена и возвращает top-K результатов.
#
# Чтобы включить жёсткую фильтрацию — задайте переменные ниже.
# Чтобы исследователь автоматически подстраивался под текст
# запроса («ищи в соцсетях», «научный факт-чек», «ищи всё»),
# оставьте INTENT_DETECTION=true (включено по дефолту) и при
# необходимости заполните SOCIAL_DOMAINS / ACADEMIC_DOMAINS /
# NEWS_DOMAINS — иначе режим будет работать вхолостую (ничего
# не будет приоритизироваться).

# Отбрасывать результаты с score ниже порога. 0.0 = не фильтровать.
MIN_RESULT_SCORE=0.0
# Сколько URL с одного запроса реально идут в LLM после реранкинга.
RESULTS_TOP_K_PER_QUERY=10
# Буст домена, если он встретился по ≥N разным запросам в итерации.
DOMAIN_BOOST_THRESHOLD=2

# ── Домены (всё опционально, по дефолту пусто) ────────────────────
# Если хотите поднять в топ нейтрального режима конкретные сайты
# (не привязываясь к типу источника) — задайте PRIORITY_DOMAINS.
# Если хотите что-то отсечь — задайте BLOCKED_DOMAINS.
#PRIORITY_DOMAINS=
#BLOCKED_DOMAINS=

# ── Адаптивные режимы (подсказка «ищи в …») ───────────────────────
# Когда пользователь явно просит конкретный тип источника,
# Researcher поднимает соответствующие домены в топ (но не блокирует
# остальные). Чтобы подсказка реально работала — заполните списки.
#
# Примеры (можно скопировать как есть, если хочется из коробки):
#SOCIAL_DOMAINS=vk.com,facebook.com,twitter.com,x.com,instagram.com,tiktok.com,reddit.com,linkedin.com
#ACADEMIC_DOMAINS=.edu,arxiv.org,scholar.google.com,pubmed.ncbi.nlm.nih.gov,nature.com,science.org,researchgate.net
#NEWS_DOMAINS=ria.ru,tass.ru,rbc.ru,vedomosti.ru,kommersant.ru,interfax.ru

# Вкл/выкл детектор намерений. true / 1 / yes = работает.
INTENT_DETECTION=true

# Свои ключевые слова для каждого режима (через запятую).
# Если оставить пустым — используются встроенные RU+EN ключевики.
#INTENT_KEYWORDS_SOCIAL=соцсет,в соц,twitter
#INTENT_KEYWORDS_ACADEMIC=научн,факт-чек,arxiv
#INTENT_KEYWORDS_NEWS=новост,сми,news
#INTENT_KEYWORDS_ALL=ищи всё,включи все,comprehensive search
