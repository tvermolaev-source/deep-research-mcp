# SearXNG (запущен как отдельный контейнер)
SEARXNG_URL=http://searxng:8080
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=ru
SEARXNG_ENGINES=google,bing,duckduckgo
SEARXNG_SAFESEARCH=0

# OpenAI-совместимый endpoint (для LLM-планирования/суммаризации)
# например, Ollama локально или Open WebUI proxy
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# Embeddings (опционально, для дедупликации)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# MCP сервер
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Лимиты
MAX_ITERATIONS_QUALITY=25
MAX_ITERATIONS_BALANCED=6
MAX_ITERATIONS_SPEED=2
MAX_PARALLEL_CRAWLS=5
MAX_RESULTS_PER_QUERY=10
CRAWL_TIMEOUT_SEC=60

# ── Фильтрация выдачи SearXNG ────────────────────────────────────────
# Значения совпадают с дефолтами в config.py — если строка здесь
# пустая, всё равно будут работать эффективные встроенные дефолты.
# Оставляйте как есть, либо подкручивайте под свой сетап.

# Отбрасываем результаты с score ниже порога (SearXNG обычно 0..~30).
# Дефолт 0.5 — отсекает явный шум (соцсети/PDF-фолдеры с score≈0.1),
# но не трогает нормальный Google/Brave (1.5–5).
MIN_RESULT_SCORE=0.5
# Сколько URL-ов с одного поискового запроса реально идут в LLM/crawl.
# Остальные отбрасываются после сортировки по score+domain-boost.
RESULTS_TOP_K_PER_QUERY=5
# Сколько раз один домен должен встретиться по разным запросам, чтобы
# получить доменный буст (поднять его в топ).
DOMAIN_BOOST_THRESHOLD=2
# Домены-мусор: соцсети, фолдеры PDF, и т.п. (через запятую).
# Чтобы отключить блэклист полностью — оставьте пустым.
BLOCKED_DOMAINS=facebook.com,fb.com,instagram.com,tiktok.com,pinterest.com,vk.com,ok.ru,linkedin.com,twitter.com,x.com,reddit.com
# Домены-приоритеты (через запятую). Дефолт — крупные СМИ и научпоп.
PRIORITY_DOMAINS=ria.ru,tass.ru,rbc.ru,vedomosti.ru,kommersant.ru,interfax.ru,hightech.fm,naukaip.ru,hse.ru,sk.ru,ras.ru
